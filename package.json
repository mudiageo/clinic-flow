{
  "name": "clinic-flow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "build:windows": "pnpm tauri build",
    "build:mac": "pnpm tauri build",
    "build:android": "pnpm tauri android build",
    "build:ios": "pnpm tauri ios build",
    "build:all": "pnpm tauri build && pnpm tauri android build",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "db:push": "drizzle-kit push",
    "db:seed": "pnpm dlx tsx --env-file=.env src/lib/server/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24",
    "@types/qrcode": "^1.5.6",
    "@vitest/browser-playwright": "^4.1.8",
    "better-auth": "~1.4.21",
    "bits-ui": "^2.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "formsnap": "^2.0.1",
    "globals": "^17.6.0",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.60.0",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn-svelte": "^1.4.1",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "svelte-sonner": "^1.1.1",
    "sveltekit-superforms": "^2.30.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "packageManager": "pnpm@11.12.0",
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@mlc-ai/web-llm": "^0.2.84",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "valibot": "^1.4.2"
  }
}